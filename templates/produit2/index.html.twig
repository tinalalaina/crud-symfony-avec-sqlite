{% extends 'base.html.twig' %}

{% block title %}Produit2 index{% endblock %}

{% block body %}
    <h1>Produit2 index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Produit</th>
                <th>Autre2</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for produit2 in produit2s %}
            <tr>
                <td>{{ produit2.id }}</td>
                <td>{{ produit2.produit }}</td>
                <td>{{ produit2.autre2 }}</td>
                <td>
                    <a href="{{ path('app_produit2_show', {'id': produit2.id}) }}">show</a>
                    <a href="{{ path('app_produit2_edit', {'id': produit2.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_produit2_new') }}">Create new</a>
{% endblock %}
